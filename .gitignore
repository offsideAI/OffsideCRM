.DS_Store
# ─────────────────────────────────────────────────────────────────────────────
# Repository-root .gitignore
#
# The vendored Twenty base CRM lives under `OffsideCRM-base/` and ships its own
# `OffsideCRM-base/.gitignore`, which governs that subtree. Patterns here that
# could collide with base source (build/, dist/, out/, coverage/) are anchored
# with a leading "/" so they apply ONLY to the repo root, not recursively into
# the base CRM or other sub-projects.
# ─────────────────────────────────────────────────────────────────────────────

# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp.*
.yarn/cache
.yarn/install-state.gz

# ── Build / compiled output (root only; sub-projects manage their own) ───────
/dist/
/build/
/out/
*.tsbuildinfo

# ── Caches (root only where the name is generic) ─────────────────────────────
/.cache/
/.nx/cache
/.nx/workspace-data
/.turbo/
.eslintcache
.oxlintcache
.swc/

# ── Environment & secrets ────────────────────────────────────────────────────
# Catch real/secret env files (.env, .env.local, .env-prod, …) but keep the
# committed examples/templates and base's shared .env.example / .env.test.
.env
.env.local
.env.*.local
.env-*
!.env-*.example
*.pem
*.key
secrets.*

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
/logs/

# ── Tests & coverage ─────────────────────────────────────────────────────────
/coverage/
.nyc_output/
/test-results/

# ── Python / Django (for _OffsideCRM-backend-django and any Python services) ─
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.sqlite3
staticfiles/

# ── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── Editors & IDEs ───────────────────────────────────────────────────────────
.idea/
*.swp
*.swo
*~
*.sublime-workspace

# ── Claude Code (root only; keep shared settings) ────────────────────────────
/.claude/*
!/.claude/settings.json

# ── Local scratch ────────────────────────────────────────────────────────────
/data/
/tmp/
*.local
.notes
