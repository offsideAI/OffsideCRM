# OffsideVentures frontend — example environment. Copy to `.env` (gitignored).

# Django backend base URL — SERVER-ONLY (never exposed to the browser; used by
# the SvelteKit server routes / BFF proxy).
API_BASE_URL=http://localhost:8000

# Mock-data mode: set to "1" to run the UI with built-in fixtures and no backend.
# PUBLIC_ vars are exposed to the browser, so this must NOT hold secrets.
PUBLIC_MOCK=1
