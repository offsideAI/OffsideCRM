# OffsideVentures backend — example environment.
# Copy to `.env` and fill in. `.env` is gitignored.

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
DEVELOPMENT_MODE=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# --- Database ---
# With DEVELOPMENT_MODE=True, SQLite is used automatically and DATABASE_URL is ignored.
# For Postgres, set DEVELOPMENT_MODE=False and provide DATABASE_URL:
# DATABASE_URL=postgres://user:password@localhost:5432/offsideventures

# --- CORS / CSRF (SvelteKit dev server origins) ---
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173

# --- Email (Djoser activation; console backend is fine for local dev) ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
MAILER_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_PORT=25
DEFAULT_FROM_EMAIL=no-reply@offsideventures.local

# --- AI (provider-agnostic; keys are read server-side ONLY) ---
AI_PROVIDER=mock            # anthropic | openai | mock  (mock works with no key)
AI_MODEL=                   # e.g. claude-sonnet-4-6 or gpt-4o-mini (blank = provider default)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
